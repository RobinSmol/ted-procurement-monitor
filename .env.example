# Copy this file to .env and fill in your values.
# Fields marked as optional already have sensible defaults.

# Database paths (optional)
# TED_DB_PATH=data/ted_database.db
# CHROMA_DB_PATH=data/chroma_database

# Email alerts (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_LOGIN=your_brevo_login@example.com
SMTP_PASSWORD=your_brevo_smtp_key
SENDER_EMAIL=your_sender@example.com

# Dashboard (optional)
# DASHBOARD_URL=http://localhost:8501